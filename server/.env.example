# Server config. Copy to .env and adjust as needed.
PORT=8787

# CHANGE THIS in production. Used to sign JWT tokens.
JWT_SECRET=please-change-this-secret

# --- Database ---
# The backend auto-selects its database:
#   • If DATABASE_URL is set  -> PostgreSQL (production, e.g. Neon free tier).
#   • Otherwise               -> local SQLite file at DB_FILE (dev / Docker).
#
# For production (Render + Neon), set DATABASE_URL to your Neon connection string:
# DATABASE_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require

# SQLite database file path (used only when DATABASE_URL is NOT set).
DB_FILE=data.db
